# EJEMPLO DE ARCHIVO .env.local
# Copia este contenido a un archivo .env o .env.local
# NUNCA commits esto a Git (está en .gitignore)

# ========================================
# CONFIGURACIÓN BÁSICA
# ========================================

PORT=5000
NODE_ENV=development

# ========================================
# MONGODB
# ========================================

MONGODB_URI=mongodb+srv://usuario:contraseña@cluster-abc123.mongodb.net/luchris_travels?retryWrites=true&w=majority

# ========================================
# JWT (Autenticación)
# ========================================

JWT_SECRET=mi_secreto_super_seguro_cambiar_en_produccion_12345

# ========================================
# STRIPE (Pagos)
# ========================================

STRIPE_SECRET_KEY=sk_test_abcdef123456789
STRIPE_PUBLISHABLE_KEY=pk_test_abcdef123456789

# ========================================
# EMAILS (Nodemailer)
# ========================================

# Para Gmail:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASSWORD=abc def ghi jkl mno (contraseña de aplicación sin espacios)
ADMIN_EMAIL=luchristravels@gmail.com

# O para SendGrid:
